# =========================
# Core behavior
# =========================
SIGAA_BASE_URL=https://sigaa.unb.br
REQUEST_TIMEOUT_SECONDS=15
CHECK_INTERVAL_SECONDS=120
MAX_RETRIES=3
BACKOFF_SECONDS=2
DRY_RUN=true

# =========================
# Telegram (optional)
# =========================
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =========================
# Email / SMTP (optional)
# =========================
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=true

# =========================
# Desktop notifications (optional)
# On Linux you can use notify-send; on Windows install win10toast
# =========================
DESKTOP_NOTIFICATIONS_ENABLED=false
